rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth.token.email == 'hagaaty@gmail.com';
    }

    // USERS
    // Users can read/update their own profile. Admins can read/update any profile.
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      // Allow user creation for any authenticated user (during signup)
      allow create: if request.auth != null;
    }
    
    // USER SUBCOLLECTIONS (Private to user or admin)
    match /users/{userId}/{collection}/{docId} {
        allow read, write, create, delete: if isOwner(userId) || isAdmin();
    }

    // PUBLIC COLLECTIONS
    // Blog posts are publicly readable. Only admins can write.
    match /blogPosts/{blogPostId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Service prices are publicly readable. Only admins can write.
    match /servicePrices/{serviceId} {
        allow read: if true;
        allow write: if isAdmin();
    }
    
    // SETTINGS (Admin only)
    match /settings/global {
        allow read: if request.auth != null; // All users can read settings
        allow write: if isAdmin();
    }
    
    // LOGS & STATS (Admin only)
    match /systemLogs/{logId} {
        allow read, write: if isAdmin();
    }
    match /dailyStats/{date} {
        allow read, write: if isAdmin();
    }
  }
}
