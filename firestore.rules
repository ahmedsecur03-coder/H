
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Check for the existence of the user document and the role field.
      // Use exists() for safe checks.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isNewUserCreation(userId, data) {
        return request.auth.uid == userId
                && data.name is string
                && data.email == request.auth.token.email
                && data.balance == 0
                && data.adBalance == 0
                && data.totalSpent == 0
                && data.role == 'user'
                && data.rank == 'مستكشف نجمي'
                && data.apiKey is string
                && data.referralCode is string
                && data.createdAt is string;
    }

    // USERS
    match /users/{userId} {
      // READ: Users can read their own profile. Admins can read any profile.
      allow read: if isOwner(userId) || isAdmin();
      
      // LIST: Admins can list all users for management purposes.
      allow list: if isAdmin();
      
      // CREATE: Any authenticated user can create their own user document.
      allow create: if isNewUserCreation(userId, request.resource.data);

      // UPDATE: Users can only update specific fields. Admins can update more fields.
      allow update: if (isOwner(userId) 
                      && request.resource.data.name == request.resource.data.name
                      && request.resource.data.avatarUrl == request.resource.data.avatarUrl
                      && request.resource.data.notificationPreferences == request.resource.data.notificationPreferences
                      && request.resource.data.notifications == request.resource.data.notifications
                      // Ensure they cannot change other fields
                      && resource.data.balance == request.resource.data.balance
                      && resource.data.adBalance == request.resource.data.adBalance
                      && resource.data.totalSpent == request.resource.data.totalSpent
                      && resource.data.role == request.resource.data.role
                      && resource.data.apiKey == request.resource.data.apiKey
                      && resource.data.rank == request.resource.data.rank
                      ) || isAdmin();
    }
    
    // USER SUBCOLLECTIONS
    match /users/{userId}/{collection}/{docId} {
        // General rule for user-owned subcollections (orders, campaigns, tickets, etc.)
        allow read, write, create, delete: if isOwner(userId) || isAdmin();
    }


    // PUBLIC COLLECTIONS
    // Blog posts are publicly readable. Only admins can write.
    match /blogPosts/{blogPostId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Service prices are publicly readable. Only admins can write.
    match /servicePrices/{serviceId} {
        allow read: if true;
        allow write: if isAdmin();
    }
    
    // SETTINGS (Admin write, authenticated users can read)
    match /settings/global {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
    
    // LOGS & STATS (Admin only)
    match /systemLogs/{logId} {
        allow read, write: if isAdmin(); 
    }
    
    match /dailyStats/{date} {
        allow read: if isAdmin();
        // Writes to dailyStats should ideally be done by a trusted server environment/function.
        // For client-side admin updates, an admin check is needed.
        allow write: if isAdmin(); 
    }
  }
}

    