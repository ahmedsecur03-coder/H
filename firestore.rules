
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =================================
    // Helper Functions
    // =================================
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Use exists() for safe checks against non-existent documents.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isNewUserCreation(userId, data) {
        // This function enforces the initial state of a new user document.
        // It's called when a user signs up.
        return request.auth.uid == userId
                && data.name is string
                && data.email == request.auth.token.email
                && data.balance == 0
                && data.adBalance == 0
                && data.totalSpent == 0
                && data.role == 'user'
                && data.rank == 'مستكشف نجمي'
                && data.apiKey is string
                && data.referralCode is string
                && data.createdAt is string;
    }

    // =================================
    // User Profiles (/users/{userId})
    // =================================
    match /users/{userId} {
      // READ: Users can read their own profile. Admins can read any profile.
      allow read: if isOwner(userId) || isAdmin();
      
      // LIST: Only Admins can list all users for management purposes.
      allow list: if isAdmin();
      
      // CREATE: Any authenticated user can create THEIR OWN user document under specific conditions.
      allow create: if isNewUserCreation(userId, request.resource.data);

      // UPDATE: 
      // - Admins can update any field.
      // - A user can only update their own non-critical fields (name, avatar, preferences).
      allow update: if isAdmin() || 
          (isOwner(userId) && 
            // List of fields a user is allowed to change themselves
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'avatarUrl', 'notificationPreferences']))
          );
    }
    
    // =================================
    // User Subcollections (/users/{userId}/{collection}/{docId})
    // =================================
    
    // This single rule covers: orders, campaigns, deposits, tickets, etc.
    // READ/WRITE: A user can manage all documents within their own subcollections. Admins can access anyone's.
    match /users/{userId}/{userCollection}/{docId} {
        allow read, write, create, delete: if isOwner(userId) || isAdmin();
    }
    
    // =================================
    // Public & Semi-Public Collections
    // =================================

    // Blog posts are publicly readable, but only admins can write.
    match /blogPosts/{blogPostId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Service prices are publicly readable, but only admins can write.
    match /servicePrices/{serviceId} {
        allow read: if true;
        allow write: if isAdmin();
    }
    
    // Global settings are readable by any authenticated user, but only writable by admins.
    match /settings/global {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
    
    // =================================
    // Admin-Only Collections (Logs & Stats)
    // =================================

    // System logs can only be read or written by admins.
    match /systemLogs/{logId} {
        allow read, write: if isAdmin(); 
    }
    
    // Daily stats can only be read or written by admins (or trusted server functions).
    match /dailyStats/{date} {
        allow read, write: if isAdmin(); 
    }
  }
}
